{
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node", "jest", "@testing-library/jest-dom"],
    "esModuleInterop": true
  },
  "include": ["src", "types"],
  "exclude": ["node_modules", "build"]
}
